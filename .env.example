# --- Instagram (burner account strongly recommended; see README warning) ---
IG_USERNAME=your_burner_username
IG_PASSWORD=your_burner_password
# Most reliable login: paste the sessionid cookie from a logged-in browser session
# (instagram.com -> DevTools -> Application -> Cookies -> sessionid)
IG_SESSIONID=
INSTAGRAPI_SESSION_PATH=data/ig.session.json
POLL_INTERVAL_SECONDS=300
POLL_JITTER_SECONDS=30
MAX_ITEMS_PER_POLL=50

# --- Gemini (classification, extraction, embeddings, CTA detection) ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# --- Deepgram (multilingual transcription: English, Hindi, Telugu, ...) ---
# Optional. When set, Deepgram nova-2 is used; otherwise local Whisper is the fallback.
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# --- Visual extraction ---
# When true, silent reels (or reels that point at on-screen content) and image
# posts are analyzed visually by Gemini, not just by transcript.
VISUAL_EXTRACTION=true

# --- API auth (any long random string; the dashboard injects it server-side) ---
API_KEY=change-me

# --- Infrastructure (defaults match docker-compose.yml; change for AWS) ---
DATABASE_URL=postgresql+psycopg://recall:recall@localhost:5433/recall
REDIS_URL=redis://localhost:6380/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=recall
S3_SECRET_KEY=recall-secret
S3_BUCKET=recall-media

# --- Whisper ---
WHISPER_MODEL_SIZE=small

# --- Fixture mode: run the full pipeline with zero external calls ---
RECALL_FAKE_INSTAGRAM=false
RECALL_FAKE_GEMINI=false
